# --- Arena API config ---
# Copy this file to `.env` on the VPS and fill in real values.

# Mongo connection (the docker-compose service name is `mongo`)
MONGODB_URI=mongodb://arena:CHANGE_ME_STRONG_PASSWORD@mongo:27017/arena?authSource=admin

# JWT — generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

# Server
PORT=4000
NODE_ENV=production

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=https://arena.example.com,http://localhost:3000

# Mongo bootstrap creds (used by docker-compose to init the DB)
MONGO_INITDB_ROOT_USERNAME=arena
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Public domain (used by Caddy for auto-SSL)
PUBLIC_DOMAIN=arena.example.com
